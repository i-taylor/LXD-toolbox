    "html": "<div class=\"new-canvas\">\n    <div class=\"sub-title\">\n        <p>Course # (written out) of the <em>[Series Title]</em> Series</p>\n    </div>\n    <section class=\"display-header\">\n        <div class=\"heading\">\n            <div>\n                <p class=\"tag\">Course # of #</p>\n                <h2>Welcome to <strong>CAI Canvas Template</strong></h2>\n                <img class=\"um-logo\" role=\"presentation\" src=\"https://shared-files.online.umich.edu/michigan-online/course-images/current/umichlogo.png\" alt=\"\" width=\"71\" height=\"75\">\n            </div>\n            <div class=\"collage\">\n                <div>&nbsp;</div>\n                <div><img src=\"https://images.unsplash.com/photo-1611131922192-9e1d9f483900\" alt=\"describe the image itself within these double quotations\"></div>\n            </div>\n        </div>\n        <div class=\"nav-links\">\n            <ul>\n                <li>\n                    <p><a title=\"Start Here: Welcome to [Course Name]\" href=\"https://courses.online.umich.edu/courses/320/modules/1793\" data-course-type=\"modules\" data-published=\"true\" data-api-endpoint=\"https://courses.online.umich.edu/api/v1/courses/320/modules/1793\" data-api-returntype=\"Module\">Start Here</a></p>\n                </li>\n                <li>\n                    <p><a title=\"0.2 Syllabus and Course Resources\" href=\"https://courses.online.umich.edu/courses/320/pages/0-dot-2-syllabus-and-course-resources\" data-course-type=\"wikiPages\" data-published=\"true\" data-api-endpoint=\"https://courses.online.umich.edu/api/v1/courses/320/pages/0-dot-2-syllabus-and-course-resources\" data-api-returntype=\"Page\">See Syllabus</a></p>\n                </li>\n                <li>\n                    <p><a title=\"Modules\" href=\"https://courses.online.umich.edu/courses/320/modules\" data-course-type=\"navigation\" data-api-endpoint=\"https://courses.online.umich.edu/api/v1/courses/320/modules\" data-api-returntype=